	.day-tab .d-lbl {
		display: block;
		font-weight: 800;
		font-size: 0.95rem;
	}
	.day-tab .d-date {
		display: block;
		font-size: 0.65rem;
		color: var(--dim);
		font-weight: 600;
	}
	.day-tab.active {
		background: var(--rainbow);
		border-color: transparent;
		color: #14101f;
	}
	.day-tab.active .d-date {
		color: rgba(20, 16, 31, 0.7);
	}
	.day-tab.is-today:not(.active) {
		border-color: var(--roo-pink);
	}

	.sched-tools {
		display: flex;
		gap: 0.5rem;
		padding-bottom: 0.55rem;
	}
	#searchBox {
		flex: 1;
		min-width: 0;
		padding: 0.5rem 0.9rem;
		border-radius: 10px;
		border: 1px solid var(--line);
		background: var(--bg-2);
		color: var(--txt);
		font-size: 0.95rem;
		outline: none;
	}
	#searchBox::placeholder {
		color: var(--dim);
	}
	#searchBox:focus {
		border-color: var(--roo-purple);
	}

	.now-strip {
		margin-bottom: 0.6rem;
		padding: 0.55rem 0.6rem 0.6rem;
		border-radius: var(--rad);
		background: linear-gradient(135deg, rgba(255, 79, 123, 0.16), rgba(176, 139, 255, 0.14));
		border: 1px solid rgba(255, 79, 123, 0.45);
	}
	.now-strip-label {
		font-size: 0.62rem;
		font-weight: 900;
		letter-spacing: 0.16em;
		color: var(--roo-pink);
		padding: 0 0.2rem 0.35rem;
	}
	.now-strip-cards {
		display: flex;
		gap: 0.45rem;
		overflow-x: auto;
		scrollbar-width: none;
	}
	.now-strip-cards::-webkit-scrollbar {
		display: none;
	}
	.now-card {
		flex-shrink: 0;
		max-width: 14rem;
		padding: 0.45rem 0.7rem;
		border-radius: 10px;
		background: rgba(18, 13, 29, 0.65);
		border-left: 3px solid var(--sc, var(--roo-pink));
		text-align: left;
	}
	.now-card .nc-a {
		display: block;
		font-weight: 800;
		font-size: 0.85rem;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	.now-card .nc-s {
		display: block;
		font-size: 0.68rem;
		color: var(--mut);
		font-weight: 600;
	}
	/* now/up-next cards hold a tap-target body + a one-tap star */
	.now-card {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		cursor: pointer;
	}
	.now-card .nc-main {
		min-width: 0;
		flex: 1;
	}
	.now-card .fav-btn {
		flex-shrink: 0;
	}
	/* "up next for you" — green/star themed variant of the now strip */
	.upnext-strip {
		background: linear-gradient(135deg, rgba(61, 220, 151, 0.16), rgba(92, 225, 230, 0.14));
		border-color: rgba(61, 220, 151, 0.45);
	}
	.upnext-strip .now-strip-label {
		color: var(--roo-green);
	}
	.upnext-strip .nc-s .nc-when {
		color: var(--roo-green);
		font-weight: 800;
	}
	.upnext-strip .nc-s .nc-when.nc-live {
		color: var(--roo-pink);
	}

	.sched-group-h {
		position: sticky;
		top: 0;
		z-index: 10;
		padding: 0.5rem 0.2rem 0.3rem;
		font-size: 0.72rem;
		font-weight: 900;
		letter-spacing: 0.12em;
		color: var(--dim);
		background: linear-gradient(var(--bg) 75%, transparent);
	}
	.set-row {
		display: flex;
		align-items: center;
		gap: 0.7rem;
		padding: 0.55rem 0.65rem;
		margin-bottom: 0.4rem;
		border-radius: var(--rad);
		background: var(--bg-2);
		border: 1px solid var(--line);
		border-left: 4px solid var(--sc, var(--line));
		transition: opacity 0.2s;
	}
	.set-row.is-past {
		opacity: 0.42;
	}
	.set-row.is-live {
		background: linear-gradient(135deg, rgba(255, 79, 123, 0.14), var(--bg-2) 55%);
		border-color: rgba(255, 79, 123, 0.55);
		border-left-color: var(--sc, var(--roo-pink));
	}
	.set-time {
		flex-shrink: 0;
		width: 4.3rem;
		text-align: center;
		line-height: 1.2;
	}
	.set-time .st-s {
		display: block;
		font-weight: 800;
		font-size: 0.92rem;
	}
	.set-time .st-e {
		display: block;
		font-size: 0.66rem;
		color: var(--dim);
		font-weight: 600;
	}
	.set-main {
		flex: 1;
		min-width: 0;
	}
	.set-artist {
		font-weight: 800;
		font-size: 1rem;
		line-height: 1.25;
		overflow-wrap: anywhere;
	}
	.set-meta {
		display: flex;
		align-items: center;
		gap: 0.45rem;
		margin-top: 0.12rem;
		font-size: 0.7rem;
		font-weight: 700;
	}
	.stage-tag {
		color: var(--sc, var(--mut));
		letter-spacing: 0.06em;
	}
	.day-tag {
		color: #14101f;
		background: var(--roo-purple);
		border-radius: 5px;
		padding: 0.05rem 0.35rem;
		font-size: 0.6rem;
		font-weight: 900;
		letter-spacing: 0.08em;
	}
	.empty-note.slim {
		padding: 0.8rem 1rem 0.2rem;
	}
	/* ── trip report ── */
	.trip-stats {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 0.45rem;
		margin-bottom: 0.5rem;
	}
	.trip-stat {
		padding: 0.6rem 0.3rem;
		border-radius: var(--rad);
		background: var(--bg-2);
		border: 1px solid var(--line);
		text-align: center;
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
	}
	.trip-stat b {
		font-size: 1.02rem;
		background: var(--rainbow);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}
	.trip-stat span {
		font-size: 0.64rem;
		color: var(--dim);
		font-weight: 700;
	}
	.trip-day-meta {
		color: var(--mut);
		font-size: 0.78rem;
		font-weight: 600;
		margin-bottom: 0.4rem;
	}
	.trip-bars {
		display: flex;
		align-items: flex-end;
		gap: 2px;
		height: 5.2rem;
		padding: 0.4rem 0.2rem 0;
		border-radius: 10px;
		background: var(--bg-2);
		border: 1px solid var(--line);
	}
	.trip-bar {
		flex: 1;
		border-radius: 3px 3px 0 0;
		background: var(--roo-blue);
		opacity: 0.85;
		min-height: 2px;
	}
	.trip-bar.peak {
		background: var(--roo-pink);
	}
	.trip-axis {
		display: flex;
		justify-content: space-between;
		padding: 0.15rem 0.2rem 0.6rem;
		font-size: 0.62rem;
		color: var(--dim);
		font-weight: 700;
	}
	.trip-foot {
		margin-top: 1rem;
		color: var(--dim);
		font-size: 0.78rem;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		align-items: flex-start;
	}
	.genre-tag {
		color: var(--dim);
		font-weight: 600;
		font-size: 0.68rem;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	.genre-tag.big {
		font-size: 0.78rem;
		color: var(--roo-purple);
		background: rgba(176, 139, 255, 0.12);
		border: 1px solid rgba(176, 139, 255, 0.35);
		border-radius: 999px;
		padding: 0.15rem 0.6rem;
	}
	.live-tag {
		color: #fff;
		background: var(--live);
		border-radius: 5px;
		padding: 0.05rem 0.35rem;
		font-size: 0.6rem;
		font-weight: 900;
		letter-spacing: 0.08em;
		animation: pulse 2s infinite;
	}
	.fav-btn {
		flex-shrink: 0;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 50%;
		font-size: 1.25rem;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--dim);
		transition: transform 0.12s;
	}
	.fav-btn:active {
		transform: scale(1.25);
	}
	.fav-btn.faved {
		color: var(--roo-orange);
	}
	.fav-btn.interested {
		font-size: 1.05rem;
	}
	.set-row.is-interested {
		opacity: 0.75;
		border-style: dashed;
	}
	/* friends also going to one of your sets */
	.friends-at {
		display: flex;
		align-items: center;
		gap: 0.35rem;
		flex-wrap: wrap;
		margin: -0.15rem 0 0.45rem;
		padding: 0.25rem 0.65rem;
		border-radius: 8px;
		background: rgba(176, 139, 255, 0.14);
		border-left: 3px solid var(--roo-purple, #b08bff);
		font-size: 0.72rem;
		font-weight: 700;
		color: #d9caff;
	}
	/* notification settings rows */
	.notif-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.8rem;
		padding: 0.6rem 0;
		border-bottom: 1px solid var(--line);
		font-weight: 700;
		font-size: 0.92rem;
	}
	.notif-row.notif-sub {
		font-weight: 600;
		color: var(--mut);
		font-size: 0.85rem;
	}
	.notif-row input[type='checkbox'] {
		width: 1.3rem;
		height: 1.3rem;
		accent-color: var(--roo-green);
	}
	.notif-row select {
		background: var(--bg-2);
		color: var(--txt);
		border: 1px solid var(--line);
		border-radius: 8px;
		padding: 0.3rem 0.5rem;
		font: inherit;
		font-size: 0.85rem;
	}
	/* rich import preview list */
	.import-list {
		max-height: 48vh;
		overflow-y: auto;
		margin: 0.1rem 0 0.3rem;
	}
	.import-day {
		font-size: 0.6rem;
		font-weight: 900;
		letter-spacing: 0.12em;
		color: var(--mut);
		margin: 0.55rem 0 0.15rem;
	}
	.import-row {
		display: flex;
		justify-content: space-between;
		gap: 0.6rem;
		font-size: 0.82rem;
		line-height: 1.45;
		padding: 0.12rem 0;
	}
	.import-row.both {
		color: var(--roo-green);
		font-weight: 700;
	}
	.import-row .ir-t {
		color: var(--mut);
		white-space: nowrap;
	}
	.walk-note {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		margin: -0.15rem 0 0.4rem;
		padding: 0.3rem 0.65rem;
		border-radius: 8px;
		background: rgba(61, 220, 151, 0.1);
		border: 1px dashed rgba(61, 220, 151, 0.4);
		color: var(--roo-green);
		font-size: 0.72rem;
		font-weight: 700;
	}
	.walk-note.tight {
		background: rgba(255, 176, 46, 0.12);
		border-color: rgba(255, 176, 46, 0.45);
		color: var(--roo-orange);
	}
	.friends-h {
		margin-top: 1rem;
	}
	.friend-card {
		position: relative;
		margin-bottom: 0.45rem;
		border-radius: var(--rad);
		background: var(--bg-2);
		border: 1px solid var(--line);
		padding: 0.1rem 0.4rem;
	}
	.friend-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
		width: calc(100% - 2rem);
		padding: 0.55rem 0.4rem;
		text-align: left;
	}
	.friend-name {
		font-weight: 800;
		font-size: 0.92rem;
	}
	.friend-meta {
		color: var(--dim);
		font-size: 0.72rem;
		font-weight: 700;
		white-space: nowrap;
	}
	.friend-rm {
		position: absolute;
		top: 0.55rem;
		right: 0.55rem;
		color: var(--dim);
		font-size: 0.85rem;
		padding: 0.2rem 0.35rem;
	}
	.friend-sets {
		padding: 0 0.5rem 0.6rem;
	}
	.friend-day {
		font-size: 0.66rem;
		font-weight: 900;
		letter-spacing: 0.12em;
		color: var(--roo-purple);
		padding: 0.35rem 0 0.15rem;
	}
	.friend-set {
		font-size: 0.8rem;
		color: var(--mut);
		padding: 0.12rem 0;
	}
	.both-tag {
		color: var(--roo-green);
		font-weight: 800;
		font-size: 0.7rem;
	}
	.empty-note {
		padding: 2.2rem 1rem;
		text-align: center;
		color: var(--dim);
		font-size: 0.9rem;
	}

	/* ───────────────────────── map ───────────────────────── */
	.map-chips {
		padding: 0.15rem 0.8rem 0.5rem;
	}
	.map-wrap {
		position: relative;
		flex: 1;
		min-height: 46dvh;
	}
	#map {
		position: absolute;
		inset: 0;
		background: #0c1410;
	}
	.map-fabs {
		position: absolute;
		right: 0.7rem;
		bottom: 1rem;
		z-index: 800;
		display: flex;
		flex-direction: column;
		gap: 0.55rem;
	}
	.fab {
		width: 2.9rem;
		height: 2.9rem;
		border-radius: 50%;
		background: rgba(18, 13, 29, 0.92);
		border: 1px solid var(--line);
		font-size: 1.25rem;
		display: flex;
		align-items: center;
		justify-content: center;
		box-shadow: 0 4px 16px rgba(0, 0, 0, 0.45);
	}
	.fab:active {
		transform: scale(0.94);
	}
	.fab.on {
		border-color: var(--roo-blue);
		box-shadow: 0 0 0 2px rgba(70, 179, 255, 0.4);
	}
	.map-banner {
		position: absolute;
		top: 0.7rem;
		left: 50%;
		transform: translateX(-50%);
		z-index: 800;
		padding: 0.45rem 0.9rem;
		border-radius: 999px;
		background: rgba(255, 176, 46, 0.95);
		color: #14101f;
		font-size: 0.8rem;
		font-weight: 800;
		white-space: nowrap;
		box-shadow: 0 4px 16px rgba(0, 0, 0, 0.4);
	}
	.nearest {
		background: var(--bg-2);
		border-top: 1px solid var(--line);
		padding: 0.55rem 0.8rem 0.7rem;
		max-height: 32dvh;
		overflow-y: auto;
	}
	.nearest-hint {
		font-size: 0.78rem;
		color: var(--dim);
		text-align: center;
		padding: 0.2rem;
	}
	.near-row {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		padding: 0.35rem 0.15rem;
		border-bottom: 1px solid rgba(55, 42, 94, 0.5);
		font-size: 0.85rem;
	}
	.near-row:last-child {
		border-bottom: none;
	}
	.near-ico {
		flex-shrink: 0;
		width: 1.5rem;
		text-align: center;
	}
	.near-name {
		flex: 1;
		min-width: 0;
		font-weight: 700;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	.near-dist {
		flex-shrink: 0;
		font-weight: 800;
		color: var(--roo-green);
		font-variant-numeric: tabular-nums;
	}
	.near-walk {
		flex-shrink: 0;
		font-size: 0.7rem;
		color: var(--dim);
		width: 4.2rem;
		text-align: right;
	}

	/* leaflet skin + markers (created by JS, so must be global) */
	.leaflet-container {
		font: inherit;
	}
	.leaflet-control-attribution {
		background: rgba(18, 13, 29, 0.7) !important;
		color: var(--dim) !important;
		font-size: 0.6rem !important;
	}
	.leaflet-control-attribution a {
		color: var(--mut) !important;
	}
	.leaflet-popup-content-wrapper,
	.leaflet-popup-tip {
		background: var(--bg-3);
		color: var(--txt);
	}
	.leaflet-popup-content {
		margin: 0.7rem 0.9rem;
		font-size: 0.85rem;
		line-height: 1.4;
	}
	.poi-pin {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		height: 100%;
		border-radius: 50%;
		background: var(--pc, #555);
		border: 2px solid rgba(255, 255, 255, 0.85);
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.55);
		font-size: 0.95rem;
	}
	.poi-pin.poi-stage {
		font-size: 1.05rem;
	}
	.poi-lbl {
		background: rgba(18, 13, 29, 0.82) !important;
		border: 1px solid var(--line) !important;
		border-radius: 7px !important;
		color: var(--txt) !important;
		font-size: 0.68rem !important;
		font-weight: 800 !important;
		padding: 0.1rem 0.4rem !important;
		box-shadow: none !important;
	}
	.poi-lbl::before {
		display: none !important;
	}
	.map-zoomed-out .poi-lbl.lbl-minor {
		display: none;
	}
	.user-dot {
		position: relative;
		width: 100%;
		height: 100%;
		border-radius: 50%;
		background: #46b3ff;
		border: 3px solid #fff;
		box-shadow: 0 0 0 6px rgba(70, 179, 255, 0.35), 0 2px 10px rgba(0, 0, 0, 0.6);
	}
	/* little arrow showing which way you're facing (device heading) */
	.user-head {
		position: absolute;
		inset: 0;
		transform-origin: 50% 50%;
		opacity: 0;
		transition: transform 0.2s ease-out, opacity 0.2s;
		pointer-events: none;
	}
	.user-head::before {
		content: '';
		position: absolute;
		top: -12px;
		left: 50%;
		transform: translateX(-50%);
		border-left: 7px solid transparent;
		border-right: 7px solid transparent;
		border-bottom: 13px solid #fff;
		/* dark outline so the heading arrow reads clearly against both the blue
		   dot and bright daytime satellite imagery */
		filter: drop-shadow(0 0 1.5px rgba(0, 0, 0, 0.9));
	}
	.focus-ping {
		font-size: 1.8rem;
		line-height: 1;
		filter: drop-shadow(0 2px 3px rgba(0, 0, 0, 0.6));
		animation: focusbounce 0.6s ease-in-out infinite alternate;
	}
	@keyframes focusbounce {
		from {
			transform: translateY(0);
		}
		to {
			transform: translateY(-6px);
		}
	}
	.crew-dot {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		height: 100%;
		border-radius: 50%;
		background: rgba(61, 220, 151, 0.9);
		border: 2px solid #fff;
		font-size: 0.9rem;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.55);
	}
	.crew-dot.stale {
		filter: grayscale(0.8);
		opacity: 0.7;
	}
	.camp-pin {
		font-size: 1.7rem;
		filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.7));
	}
	.route-arrow {
		color: #ffe66d;
		font-size: 1.1rem;
		text-shadow: 0 1px 4px rgba(0, 0, 0, 0.8);
		display: flex;
		align-items: center;
		justify-content: center;
		width: 22px;
		height: 22px;
	}
	.route-step {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
		background: rgba(255, 230, 109, 0.92);
		color: #14101f;
		font-size: 0.66rem;
		font-weight: 900;
		border-radius: 999px;
		padding: 0.08rem 0.4rem;
		white-space: nowrap;
		box-shadow: 0 1px 5px rgba(0, 0, 0, 0.5);
	}
	.route-step span {
		font-weight: 700;
	}
	.qr-wrap {
		position: fixed;
		inset: 0;
		z-index: 3200;
		background: #fff;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 1rem;
		padding: 1.5rem;
	}
	.qr-name {
		color: #14101f;
		font-size: 1.3rem;
		font-weight: 900;
		text-align: center;
	}
	#qrCanvas {
		width: min(78vw, 24rem) !important;
		height: auto !important;
		image-rendering: pixelated;
	}
	.qr-hint {
		color: #5a5470;
		font-size: 0.9rem;
		font-weight: 600;
		text-align: center;
	}
	.qr-share-actions {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		width: min(20rem, 82vw);
	}
	.share-opt {
		padding: 0.7rem 1rem;
		border-radius: 12px;
		border: 1.5px solid #14101f;
		background: #fff;
		color: #14101f;
		font-size: 0.95rem;
		font-weight: 800;
	}
	.share-opt:active {
		transform: scale(0.98);
	}
	.share-opt-primary {
		background: #14101f;
		color: #fff;
	}
	.qr-close {
		background: #14101f;
		border-color: #14101f;
		color: #fff;
	}
	.compass-wrap {
		position: fixed;
		inset: 0;
		z-index: 3000;
		background: radial-gradient(circle at 50% 38%, #221a3e, #0b0814 70%);
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.7rem;
	}
	.compass-close {
		position: absolute;
		top: calc(0.9rem + env(safe-area-inset-top, 0px));
		right: 0.9rem;
	}
	.compass-name {
		font-size: 1.15rem;
		font-weight: 900;
		padding: 0.5rem 1.1rem;
		border-radius: 999px;
		background: var(--bg-2);
		border: 1px solid var(--line);
	}
	.compass-arrow-box {
		width: min(58vw, 16rem);
		height: min(58vw, 16rem);
		border-radius: 50%;
		border: 2px solid var(--line);
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(28, 21, 48, 0.6);
	}
	.compass-arrow {
		font-size: min(34vw, 9rem);
		line-height: 1;
		background: var(--rainbow);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
		transition: transform 0.3s ease-out;
		will-change: transform;
	}
	.compass-dist {
		font-size: 1.5rem;
		font-weight: 900;
		color: var(--roo-green);
	}
	.compass-hint {
		color: var(--mut);
		font-size: 0.85rem;
		font-weight: 600;
	}
	.compass-age {
		color: var(--dim);
		font-size: 0.72rem;
		min-height: 1em;
	}
	.compass-cycle {
		color: var(--mut);
		font-size: 0.78rem;
		font-weight: 700;
		padding: 0.25rem 0.7rem;
		border-radius: 999px;
		background: transparent;
		border: 1px solid var(--line);
		margin-top: -0.2rem;
	}
	.pop-events {
		margin-top: 0.4rem;
		border-top: 1px solid var(--line);
		padding-top: 0.3rem;
	}
	.pop-ev-h {
		font-size: 0.66rem;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--dim);
		margin-bottom: 0.15rem;
	}
	.pop-ev {
		display: flex;
		justify-content: space-between;
		gap: 0.6rem;
		font-size: 0.78rem;
		line-height: 1.5;
	}
	.pop-ev .pe-a {
		font-weight: 700;
	}
	.pop-ev .pe-t {
		color: var(--mut);
		white-space: nowrap;
	}
	.pop-actions {
		margin-top: 0.4rem;
	}
	.pop-guide {
		background: var(--roo-green);
		color: #0b0814;
	}
	.user-dot.stale {
		background: #8fa3ad;
		box-shadow: 0 0 0 6px rgba(143, 163, 173, 0.3);
	}
	.pop-btn {
		display: inline-block;
		margin-top: 0.4rem;
		padding: 0.3rem 0.7rem;
		border-radius: 8px;
		background: var(--roo-blue);
		border: none;
		color: #fff;
		font-weight: 700;
		font-size: 0.78rem;
	}
	.pop-btn-danger {
		background: var(--roo-pink);
	}
	.pop-desc {
		color: var(--mut);
		font-size: 0.78rem;
		margin-top: 0.15rem;
	}
	.pop-now {
		margin-top: 0.35rem;
		color: var(--roo-pink);
		font-weight: 800;
		font-size: 0.8rem;
	}
	.pop-next {
		color: var(--mut);
		font-size: 0.76rem;
		font-weight: 600;
	}

	/* ── bottom sheets (artist detail / pin / help) ── */
	.sheet-wrap {
		position: fixed;
		inset: 0;
		z-index: 3000;
		background: rgba(8, 5, 16, 0.65);
		backdrop-filter: blur(3px);
		-webkit-backdrop-filter: blur(3px);
		display: flex;
		align-items: flex-end;
		justify-content: center;
	}
	.sheet {
		width: 100%;
		max-width: 560px;
		max-height: 88dvh;
		overflow-y: auto;
		background: var(--bg-2);
		border: 1px solid var(--line);
		border-bottom: none;
		border-radius: 22px 22px 0 0;
		animation: sheet-up 0.22s ease-out;
	}
	@keyframes sheet-up {
		from {
			transform: translateY(40px);
			opacity: 0.5;
		}
	}
	.sheet-img {
		position: relative;
		height: 11rem;
		background: var(--bg-3) center/cover no-repeat;
		border-radius: 22px 22px 0 0;
	}
	.sheet-img.no-img {
		height: 3.2rem;
	}
	.sheet-img::after {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(transparent 40%, var(--bg-2));
	}
	.sheet-close {
		position: absolute;
		top: 0.6rem;
		right: 0.6rem;
		z-index: 2;
		width: 2.1rem;
		height: 2.1rem;
		border-radius: 50%;
		background: rgba(8, 5, 16, 0.6);
		color: #fff;
		font-size: 0.95rem;
	}
	.sheet-close.static {
		position: static;
		flex-shrink: 0;
	}
	.sheet-body {
		padding: 0.4rem 1.1rem 1.3rem;
	}
	.sheet-title {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		flex-wrap: wrap;
	}
	.sheet-title h3 {
		margin: 0.3rem 0;
		font-size: 1.35rem;
		font-weight: 900;
	}
	.sheet-desc {
		margin: 0.25rem 0 0.4rem;
		color: var(--mut);
		font-size: 0.92rem;
	}
	.sheet-bio {
		margin: 0.1rem 0 0.5rem;
		color: var(--mut);
		font-size: 0.85rem;
		line-height: 1.5;
	}
	.sheet-links {
		display: flex;
		gap: 0.4rem;
		flex-wrap: wrap;
		margin: 0.1rem 0 0.7rem;
	}
	.link-chip {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		padding: 0.3rem 0.7rem;
		border-radius: 999px;
		background: var(--bg-3);
		border: 1px solid var(--line);
		color: var(--mut);
		font-size: 0.74rem;
		font-weight: 700;
		text-decoration: none;
		max-width: 100%;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	/* ── pet + quest ── */
	.pet-box {
		display: flex;
		align-items: center;
		gap: 0.8rem;
		margin-bottom: 0.7rem;
		padding: 0.6rem 0.8rem;
		border-radius: var(--rad);
		background: linear-gradient(135deg, rgba(176, 139, 255, 0.12), var(--bg-2) 60%);
		border: 1px solid var(--line);
	}
	.pet-svg {
		width: 3.6rem;
		height: 3.6rem;
		flex-shrink: 0;
	}
	.pet-svg svg {
		width: 100%;
		height: 100%;
	}
	.pet-happy .pet-svg {
		animation: pet-bounce 2.2s ease-in-out infinite;
	}
	.pet-party .pet-svg {
		animation: pet-rave 0.5s ease-in-out infinite;
	}
	.pet-thirsty .pet-svg {
		filter: saturate(0.45);
		transform: rotate(6deg);
	}
	.pet-parched .pet-svg {
		filter: grayscale(0.9);
		animation: pet-droop 3s ease-in-out infinite;
	}
	@keyframes pet-bounce {
		50% {
			transform: translateY(-4px);
		}
	}
	@keyframes pet-rave {
		25% {
			transform: rotate(-8deg) scale(1.06);
		}
		75% {
			transform: rotate(8deg) scale(1.06);
		}
	}
	@keyframes pet-droop {
		50% {
			transform: rotate(10deg) translateY(2px);
		}
	}
	.pet-info {
		flex: 1;
		min-width: 0;
	}
	.pet-name {
		font-weight: 900;
		font-size: 1rem;
		padding: 0;
	}
	.pet-mood {
		color: var(--mut);
		font-size: 0.76rem;
	}
	.pet-badges {
		font-size: 0.8rem;
		margin-top: 0.15rem;
		letter-spacing: 0.15em;
	}
	.pet-water {
		flex-shrink: 0;
		width: 2.6rem;
		height: 2.6rem;
		border-radius: 50%;
		background: rgba(70, 179, 255, 0.15);
		border: 1px solid rgba(70, 179, 255, 0.5);
		font-size: 1.2rem;
	}
	.quest-box {
		margin-top: 1rem;
		padding: 0.75rem 0.9rem;
		border-radius: var(--rad);
		background: var(--bg-2);
		border: 1px solid var(--line);
	}
	.quest-head {
		display: flex;
		justify-content: space-between;
		font-weight: 900;
		font-size: 0.95rem;
		margin-bottom: 0.45rem;
	}
	.quest-count {
		color: var(--roo-orange);
	}
	.quest-bar {
		height: 0.45rem;
		border-radius: 999px;
		background: var(--bg);
		overflow: hidden;
		margin-bottom: 0.55rem;
	}
	.quest-fill {
		height: 100%;
		background: var(--rainbow);
		border-radius: 999px;
		transition: width 0.4s;
	}
	.quest-row {
		display: flex;
		align-items: center;
		gap: 0.55rem;
		padding: 0.32rem 0;
		font-size: 0.84rem;
		color: var(--txt);
	}
	.quest-row.done .q-label {
		color: var(--dim);
		text-decoration: line-through;
	}
	.q-check {
		width: 1.5rem;
		text-align: center;
		flex-shrink: 0;
	}
	.q-label {
		flex: 1;
	}
	.q-hint {
		color: var(--roo-green);
		font-size: 0.7rem;
		font-weight: 700;
		white-space: nowrap;
	}
	.quest-tip {
		margin-top: 0.4rem;
		color: var(--dim);
		font-size: 0.7rem;
	}
	.quest-won {
		margin-top: 0.5rem;
		text-align: center;
		font-weight: 800;
		color: var(--roo-orange);
		animation: pulse 1.6s infinite;
	}
	.sheet-when {
		margin: 0.2rem 0 0.8rem;
		color: var(--mut);
		font-size: 0.85rem;
		font-weight: 600;
	}
	.sheet-actions {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}
	.sheet-btn {
		flex: 1;
		min-width: 8rem;
		text-align: center;
		padding: 0.65rem 0.6rem;
		border-radius: 12px;
		background: var(--bg-3);
		border: 1px solid var(--line);
		color: var(--txt);
		font-weight: 800;
		font-size: 0.88rem;
		text-decoration: none;
	}
	.sheet-btn.faved {
		color: var(--roo-orange);
		border-color: rgba(255, 176, 46, 0.5);
	}
	.sheet-spotify {
		background: #1db954;
		border-color: transparent;
		color: #06150b;
	}
	.sheet-primary {
		background: var(--rainbow);
		border-color: transparent;
		color: #14101f;
	}
	/* pin sheet */
	.pin-sheet h3,
	.help-sheet h3 {
		margin: 0.5rem 0 0.2rem;
		font-size: 1.15rem;
		font-weight: 900;
	}
	.pin-hint {
		color: var(--dim);
		font-size: 0.82rem;
		margin: 0.1rem 0 0.6rem;
	}
	.pin-emojis {
		display: grid;
		grid-template-columns: repeat(6, 1fr);
		gap: 0.4rem;
		margin-bottom: 0.7rem;
	}
	.pin-emoji {
		font-size: 1.5rem;
		padding: 0.45rem 0;
		border-radius: 12px;
		background: var(--bg-3);
		border: 1px solid var(--line);
	}
	.pin-emoji.active {
		border-color: var(--roo-orange);
		box-shadow: 0 0 0 2px rgba(255, 176, 46, 0.4);
	}
	#pinName {
		width: 100%;
		padding: 0.6rem 0.85rem;
		margin-bottom: 0.8rem;
		border-radius: 10px;
		border: 1px solid var(--line);
		background: var(--bg);
		color: var(--txt);
		font-size: 0.95rem;
		outline: none;
	}
	#pinName:focus {
		border-color: var(--roo-purple);
	}
	/* help sheet */
	.help-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.6rem;
	}
	.help-list {
		margin: 0.5rem 0;
		padding-left: 1.1rem;
		color: var(--mut);
		font-size: 0.86rem;
	}
	.help-list li {
		margin: 0.55rem 0;
	}
	.help-list b {
		color: var(--txt);
	}
	/* ── food vendor directory ── */
	.food-search {
		width: 100%;
		padding: 0.6rem 0.8rem;
		margin-bottom: 0.7rem;
		background: var(--bg-3);
		border: 1px solid var(--line);
		border-radius: 12px;
		color: var(--txt);
		font-size: 0.92rem;
	}
	.food-list {
		max-height: 56vh;
		overflow-y: auto;
	}
	.food-group-h {
		position: sticky;
		top: 0;
		background: var(--bg-2, #1a1430);
		padding: 0.45rem 0.1rem 0.3rem;
		font-size: 0.82rem;
		font-weight: 700;
		color: #c9b8ff;
	}
	.food-group-h span {
		color: var(--mut);
		font-weight: 500;
	}
	.food-item {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.42rem 0.1rem;
		border-bottom: 1px solid var(--line);
		font-size: 0.88rem;
	}
	.food-item .fi-emoji {
		flex: 0 0 1.3rem;
		text-align: center;
	}
	.food-note {
		margin: 0.7rem 0 0;
		font-size: 0.76rem;
		color: var(--mut);
		line-height: 1.4;
	}

	/* ── first-run welcome / setup ── */
	.welcome-hero {
		text-align: center;
		margin-bottom: 1rem;
	}
	.welcome-emoji {
		font-size: 2.6rem;
		line-height: 1;
		animation: welcomeBob 2.6s ease-in-out infinite;
	}
	@keyframes welcomeBob {
		50% {
			transform: translateY(-6px) rotate(-4deg);
		}
	}
	.welcome-hero h3 {
		margin: 0.5rem 0 0.2rem;
		font-size: 1.3rem;
	}
	.welcome-sub {
		color: var(--mut);
		font-size: 0.86rem;
		margin: 0;
	}
	.welcome-steps {
		display: flex;
		flex-direction: column;
		gap: 0.55rem;
		margin-bottom: 0.6rem;
	}
	.wstep {
		display: flex;
		align-items: center;
		gap: 0.7rem;
		padding: 0.65rem 0.7rem;
		background: var(--bg-3);
		border: 1px solid var(--line);
		border-radius: 13px;
		transition: border-color 0.25s;
	}
	.wstep.done {
		border-color: var(--roo-green, #3ddc97);
	}
	.wicon {
		flex: 0 0 2.3rem;
		height: 2.3rem;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 1.3rem;
		background: rgba(124, 92, 255, 0.14);
		border-radius: 11px;
	}
	.wmain {
		flex: 1;
		min-width: 0;
	}
	.wtitle {
		font-weight: 700;
		font-size: 0.92rem;
	}
	.wdesc {
		color: var(--mut);
		font-size: 0.78rem;
		line-height: 1.35;
	}
	.wbtn {
		flex: 0 0 auto;
		background: var(--roo-purple, #7c5cff);
		color: #fff;
		border: none;
		border-radius: 99px;
		padding: 0.4rem 0.85rem;
		font-size: 0.8rem;
		font-weight: 700;
		cursor: pointer;
		white-space: nowrap;
	}
	.wbtn:disabled,
	.wbtn.wbtn-on {
		background: rgba(61, 220, 151, 0.18);
		color: var(--roo-green, #3ddc97);
		cursor: default;
	}
	.welcome-skip {
		display: block;
		margin: 0.4rem auto 0;
		background: none;
		border: none;
		color: var(--mut);
		font-size: 0.82rem;
		text-decoration: underline;
		cursor: pointer;
	}
	.help-install {
		margin-top: 0.8rem;
	}
	.help-install p {
		color: var(--mut);
		font-size: 0.84rem;
		background: var(--bg-3);
		border: 1px solid var(--line);
		border-radius: 10px;
		padding: 0.6rem 0.8rem;
	}
	.ios-share {
		display: inline-block;
		transform: rotate(-90deg);
		font-weight: 900;
	}
	.help-foot {
		margin: 0.9rem 0 0;
		color: var(--dim);
		font-size: 0.72rem;
		text-align: center;
	}

	/* ── official map viewer ── */
	.omap-wrap {
		position: fixed;
		inset: 0;
		z-index: 3000;
		background: #0b0814;
		display: flex;
		flex-direction: column;
	}
	.omap-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.6rem;
		padding: 0.55rem 0.8rem;
		padding-top: calc(0.55rem + env(safe-area-inset-top, 0px));
		border-bottom: 1px solid var(--line);
	}
	.omap-tabs {
		display: flex;
		gap: 0.4rem;
	}
	.omap-tabs button {
		padding: 0.4rem 0.95rem;
		border-radius: 999px;
		background: var(--bg-2);
		border: 1px solid var(--line);
		color: var(--mut);
		font-weight: 700;
		font-size: 0.85rem;
	}
	.omap-tabs button.active {
		background: var(--rainbow);
		border-color: transparent;
		color: #14101f;
	}
	.omap-close {
		width: 2.2rem;
		height: 2.2rem;
		border-radius: 50%;
		background: var(--bg-3);
		border: 1px solid var(--line);
		color: var(--txt);
	}
	#omapMap {
		flex: 1;
		background: #0b0814;
	}
	.omap-note {
		padding: 0.45rem 0.9rem calc(0.45rem + env(safe-area-inset-bottom, 0px));
		font-size: 0.74rem;
		color: var(--roo-orange);
		font-weight: 700;
		text-align: center;
		border-top: 1px solid var(--line);
	}

	/* ───────────────────────── plan ───────────────────────── */
	.plan-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
		flex-wrap: wrap;
		padding-bottom: 0.5rem;
	}
	.plan-head h2 {
		margin: 0;
		font-size: 1.25rem;
		font-weight: 900;
	}
	.plan-actions {
		display: flex;
		gap: 0.45rem;
		flex-wrap: wrap;
	}
	/* editable display name used for sharing (links/QR/crew) */
	.name-chip {
		display: block;
		width: 100%;
		text-align: left;
		margin-bottom: 0.6rem;
		padding: 0.4rem 0.7rem;
		border-radius: 10px;
		background: var(--bg-2);
		border: 1px solid var(--line);
		color: var(--mut);
		font-size: 0.8rem;
		font-weight: 600;
	}
	.name-chip b {
		color: var(--txt);
	}
	.name-chip .name-edit {
		color: var(--roo-blue);
		font-weight: 800;
	}
	.plan-day-h {
		padding: 0.8rem 0.2rem 0.35rem;
		font-size: 0.78rem;
		font-weight: 900;
		letter-spacing: 0.12em;
		color: var(--roo-purple);
	}
	.conflict-note {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		margin: -0.15rem 0 0.4rem;
		padding: 0.3rem 0.65rem;
		border-radius: 8px;
		background: rgba(255, 176, 46, 0.14);
		border: 1px solid rgba(255, 176, 46, 0.4);
		color: var(--roo-orange);
		font-size: 0.72rem;
		font-weight: 700;
	}

	/* ───────────────────────── info ───────────────────────── */
	.weather-card {
		margin-bottom: 0.8rem;
