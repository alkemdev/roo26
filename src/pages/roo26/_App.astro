---
// _App.astro — the entire Roo '26 guide app, rendered as a standalone page.
// Wrapper pages (index/map/plan/info.astro) pass the initial tab; client-side
// pushState handles switching between them without a reload.
interface Props {
	tab?: 'schedule' | 'map' | 'plan' | 'info'
	standalone?: boolean // app is served at the domain root (roo26.alkem.dev)
}
const { tab = 'schedule' } = Astro.props

const titles: Record<string, string> = {
	schedule: "Roo '26 — Bonnaroo 2026 Schedule & Set Times",
	map: "Roo '26 — Interactive Bonnaroo 2026 Map",
	plan: "Roo '26 — My Bonnaroo 2026 Plan",
	info: "Roo '26 — Bonnaroo 2026 Survival Guide",
}
const title = titles[tab]
const desc =
	"Unofficial interactive guide to Bonnaroo 2026 (June 11–14, Manchester TN): full set times, live map with your location, water & medical stations, and a personal planner. Works great on your phone."

// Canonical home is roo26.alkem.dev (Astro.site) — absolute canonical/OG URLs
// so shared links always resolve to the subdomain.
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : undefined
const ogImage = Astro.site ? new URL('/roo26-icon-512.png', Astro.site).href : '/roo26-icon-512.png'
---

<!doctype html>
<html lang="en" data-tab={tab}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<title>{title}</title>
		<meta name="description" content={desc} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={desc} />
		<meta property="og:type" content="website" />
		<meta property="og:image" content={ogImage} />
		{canonical && <link rel="canonical" href={canonical} />}
		{canonical && <meta property="og:url" content={canonical} />}
		<meta name="theme-color" content="#120d1d" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
		<meta name="apple-mobile-web-app-title" content="Roo '26" />
		<meta name="robots" content="index,follow" />
		<link rel="manifest" href="/roo26-root.webmanifest" />
		<link rel="apple-touch-icon" href="/roo26-icon-180.png" />
		<link rel="icon" href="/roo26-icon-192.png" type="image/png" />
	</head>

	<body>
		<header class="topbar">
			<div class="brand">
				<span class="brand-roo">ROO</span><span class="brand-yr">’26</span>
				<span class="brand-sub">The Farm · Manchester, TN · Jun 11–14</span>
			</div>
			<div class="topbar-right">
				<div class="live-pill" id="livePill">…</div>
				<button class="help-btn" id="notifBtn" aria-label="Notifications" hidden>🔔</button>
				<button class="help-btn" id="helpBtn" aria-label="Help & install">?</button>
			</div>
		</header>

		<!-- most-recent news/alert — tap for the full story. Auto-shows when there's
		     an undismissed item; severity drives the color. -->
		<button class="news-banner" id="newsBanner" hidden>
			<span class="news-banner-dot" id="newsBannerDot"></span>
			<span class="news-banner-text" id="newsBannerText"></span>
			<span class="news-banner-cta">Read ›</span>
			<span class="news-banner-x" id="newsBannerX" role="button" aria-label="Dismiss">✕</span>
		</button>

		<div class="wx-alert" id="wxAlert" hidden>
			<span id="wxAlertText"></span>
			<button id="wxAlertClose" aria-label="Dismiss alert">✕</button>
		</div>

		<main>
			<!-- ════════════ SCHEDULE ════════════ -->
			<section class="view" id="view-schedule">
				<div class="day-tabs" id="dayTabs"></div>

				<div class="sched-tools">
					<input
						type="search"
						id="searchBox"
						placeholder="Search artists…"
						autocomplete="off"
						enterkeyhint="search"
					/>
					<button class="tool-btn" id="nowJump" title="Jump to what's on now">Now</button>
					<button class="tool-btn" id="hidePast" title="Hide sets that already ended" aria-pressed="false">Hide past</button>
				</div>

				<div class="chip-row" id="stageChips"></div>

				<div class="now-strip upnext-strip" id="upNextStrip" hidden>
					<div class="now-strip-label">⭐ UP NEXT FOR YOU</div>
					<div class="now-strip-cards" id="upNextCards"></div>
				</div>

				<div class="now-strip" id="nowStrip" hidden>
					<div class="now-strip-label">ON NOW</div>
					<div class="now-strip-cards" id="nowCards"></div>
				</div>

				<div id="schedList" class="sched-list"></div>
			</section>

			<!-- ════════════ MAP ════════════ -->
			<section class="view" id="view-map">
				<div class="chip-row map-chips" id="poiChips"></div>
				<div class="map-wrap">
					<div id="map"></div>
					<div class="map-fabs">
						<button class="fab" id="fabOmap" title="Official festival map">📜</button>
						<button class="fab" id="fabPin" title="Mark a camp or meetup spot">⛺</button>
						<button class="fab" id="fabHome" title="Compass to your camp">🧭</button>
						<button class="fab fab-locate" id="fabLocate" title="Show my location">📍</button>
					</div>
					<div class="map-banner" id="tentBanner" hidden>Tap the map to place the pin</div>
				</div>
				<div class="nearest" id="nearestPanel">
					<div class="nearest-hint" id="nearestHint">
						Tap 📍 to see your distance to every stage, water station and camp. Tap ⛺ to mark
						your camp and friends' camps.
					</div>
					<div class="nearest-list" id="nearestList"></div>
				</div>
			</section>

			<!-- ════════════ MY PLAN ════════════ -->
			<section class="view" id="view-plan">
				<div class="plan-head">
					<h2>My Roo</h2>
					<div class="plan-actions">
						<button class="tool-btn" id="sharePlan">📤 Share my Roo</button>
						<button class="tool-btn" id="icsPlan" title="Add to your calendar">📅</button>
						<button class="tool-btn tool-danger" id="clearPlan">Clear</button>
					</div>
				</div>
				<button class="name-chip" id="nameChip" title="This name is used on your shared links, QR codes & crew"></button>
				<div id="planBody"></div>
			</section>

			<!-- ════════════ INFO ════════════ -->
			<section class="view" id="view-info">
				<!-- scrollable festival news/alerts feed (newest first) -->
				<div class="news-strip-wrap" id="newsStripWrap" hidden>
					<div class="news-strip-head">📣 Festival News &amp; Alerts</div>
					<div class="news-strip" id="newsStrip"></div>
				</div>
				<div class="weather-card" id="weatherCard">
					<div class="weather-head">
						<h2>Weather on the Farm</h2>
						<span class="weather-src" id="weatherSrc">forecast</span>
					</div>
					<div class="weather-days" id="weatherDays">Loading forecast…</div>
				</div>
				<div id="infoBody">
					<details class="info-sec" open>
						<summary>⏰ Hours &amp; key times</summary>
						<div class="sec-body">
							<ul>
								<li><b>Centeroo</b> opens Thu Jun 11 at <b>1 PM</b>, then runs <b>24 hours non-stop</b> until Sun ~10 PM.</li>
								<li><b>Campground tollbooths</b>: open 8 AM daily — be <b>in line by 8 PM</b>. Campgrounds close Mon Jun 15 at noon.</li>
								<li><b>Box office</b>: Coffee County Central High School (100 Red Raider Dr, Manchester), 8 AM–9 PM daily through Sunday. Will Call + wristband issues; original purchaser needs government ID.</li>
								<li><b>1-day tickets</b> (new in '26): enter from 11 AM; must exit Centeroo by 8 AM the next day.</li>
								<li><b>Re-entry</b>: unlimited between Centeroo and campgrounds (scan your wristband). Driving off-site costs a <b>$40 vehicle re-entry fee</b>. Day parking has <b>no</b> in-and-out.</li>
								<li><b>Headliners</b> (per the official posters): Thu Skrillex 11 PM · Fri The Strokes 11 PM · Sat RÜFÜS DU SOL 11:10 PM · Sun Noah Kahan 9:30 PM closes the Farm.</li>
								<li><b>Outeroo never sleeps</b>: plaza stages (Why, When, Groop, The Grove, Silent Disco) run late-night programming beyond the Centeroo grid in this app — check the boards at your Plaza.</li>
							</ul>
						</div>
					</details>

					<details class="info-sec">
						<summary>🎒 What you can bring (Centeroo)</summary>
						<div class="sec-body">
							<h4>Bag policy — all bags searched</h4>
							<ul>
								<li><span class="ok">OK</span> Small bag / fanny pack <b>6″×9″ or less</b> (one pocket, doesn't need to be clear).</li>
								<li><span class="ok">OK</span> Bigger bags only if <b>clear</b> and under <b>12″×6″×12″</b>.</li>
								<li><span class="ok">OK</span> <b>Hydration packs</b> (CamelBak) — bring it <b>empty</b>; max 2 main + 1 small compartment. Free refills inside.</li>
							</ul>
							<h4>Allowed</h4>
							<ul>
								<li><span class="ok">✓</span> Empty reusable water bottles, misting fans, battery packs, binoculars</li>
								<li><span class="ok">✓</span> <b>Non-aerosol</b> sunscreen — <span class="warn">3.4 oz or less</span> (strict; verify at gate)</li>
								<li><span class="ok">✓</span> Blankets / towels to sit on; point-and-shoot cameras</li>
								<li><span class="ok">✓</span> Totems ≤ 7 ft, ≤ 1″ diameter, light materials only</li>
								<li><span class="ok">✓</span> Factory-sealed Naloxone (Narcan)</li>
							</ul>
							<h4>Banned in Centeroo</h4>
							<ul>
								<li><span class="no">✗</span> <b>Chairs of any kind</b>, coolers, umbrellas, hammocks</li>
								<li><span class="no">✗</span> Outside food / drinks / alcohol; aerosols (incl. aerosol sunscreen)</li>
								<li><span class="no">✗</span> Multi-pocket backpacks, selfie sticks / tripods / pro lenses</li>
								<li><span class="no">✗</span> Wagons, bikes, scooters, skateboards, glow sticks, laser pointers</li>
							</ul>
							<p>
								Final authority is the
								<a href="https://support.bonnaroo.com/hc/en-us/articles/4402712374420-What-items-are-allowed-and-prohibited" target="_blank" rel="noopener">official allowed-items list</a> — it changes, and the gate decides.
							</p>
						</div>
					</details>

					<details class="info-sec">
						<summary>⛺ Campground rules (Outeroo)</summary>
						<div class="sec-body">
							<ul>
								<li><span class="ok">✓</span> Food and drinks at camp. Alcohol limits per person: 2 cases of beer, 2 boxes of wine (per car), 1× 1–1.75 L liquor (per car). <span class="no">No glass anywhere.</span></li>
								<li><span class="ok">✓</span> Camp chairs, portable grills, full-size sunscreen, strollers</li>
								<li><span class="ok">✓</span> One generator per vehicle (under 4 kW)</li>
								<li><span class="no">✗</span> Kegs, ground fires, fireworks, drones, weapons, pets (service animals OK)</li>
								<li>Camping is in lettered pods around <b>Plazas</b> — each Plaza has info, 24-hr medical + security, water, showers (~$7–10), general stores, charging, and Wi-Fi.</li>
								<li>General stores sell ice, water, beer, food, batteries and sundries.</li>
								<li>Community camps are back: SoloRoo, SoberRoo, FamilyRoo, The Beyond.</li>
							</ul>
						</div>
					</details>

					<details class="info-sec">
						<summary>💧 Water, medical &amp; safety</summary>
						<div class="sec-body">
							<ul>
								<li><b>Free filtered water</b> refill stations throughout Centeroo and at every Plaza — keep that bottle moving.</li>
								<li><b>Medical tents</b>: in Centeroo and at every Plaza, staffed <b>24/7</b> (nurses, physicians, crisis counselors). Roaming medics in the crowd.</li>
								<li>Need help fast? Grab any staff or a <b>SafeFest yellow shirt</b> (helping-hand logo) — or call 911 for true emergencies.</li>
								<li>Narcan is allowed through the gates (factory-sealed). Crisis counselors are on site around the clock.</li>
								<li><b>Heat plan</b>: highs near 90°F — electrolytes, shade breaks, wide-brim hat. Cooling spots are listed at the Accessibility Center; misting tent at Accessible Camping.</li>
								<li><b>Storm plan</b>: listen for announcements on <b>Bonnaroo Radio 101.5 FM</b>, the Festiverse app push alerts, and @Bonnaroo. Friday + Sunday look stormy — know your nearest exit and your car's location.</li>
							</ul>
						</div>
					</details>

					<details class="info-sec">
						<summary>🚗 Getting there &amp; around</summary>
						<div class="sec-body">
							<ul>
								<li><b>From Nashville</b>: I-24 E to Exit 111B (TN-55 E). <b>From Chattanooga</b>: I-24 W to Exit 111.</li>
								<li><b>Rideshare / drop-off</b>: use <b>2465 New Bushy Branch Rd, Manchester TN</b> (routes to the East Tollbooth). Rides back out are scarce — schedule your return in advance.</li>
								<li><b>Day parking</b>: opens 11 AM, closes 6 AM next day, no in-and-out; cars left past 9 AM after validity may be towed.</li>
								<li><b>Nashville shuttle</b>: official round-trips depart downtown twice daily, with a new closer drop-off for '26 — passes at bonnaroo.frontgatetickets.com.</li>
								<li><b>Accessibility</b>: ADA shuttles, viewing platforms, Accessible Camping with misting tent. Contact access@bonnaroo.com.</li>
							</ul>
						</div>
					</details>

					<details class="info-sec">
						<summary>💳 Money, phone &amp; lockers</summary>
						<div class="sec-body">
							<ul>
								<li>The whole Farm is <b>cashless</b> — activate your wristband's tap-to-pay and link a card (PayPal/Venmo/credit/debit) with a PIN before you hit the lines. Problems → Box Office or any info booth.</li>
								<li>ATMs exist on site but you shouldn't need cash.</li>
								<li><b>Lockers</b> (Centeroo + camp) include unlimited charging-pack swaps — entertainmentlockers.com. Free first-come charging + Wi-Fi at every Plaza.</li>
								<li><b>Cell tips</b>: networks crawl near stages — text instead of calling, pre-download maps and this page, and set a physical meetup spot with your crew.</li>
								<li><b>Bonnaroo Radio 101.5 FM</b> carries on-site announcements.</li>
							</ul>
						</div>
					</details>

					<details class="info-sec">
						<summary>🌱 What's new in 2026</summary>
						<div class="sec-body">
							<ul>
								<li>After the 2025 flood cancellation: ~100+ acres of new grass, new drainage, reinforced runoff paths, 1M+ sq ft of new internal roads, and flood-prone campsites removed.</li>
								<li>Camping entry now starts <b>Wednesday</b>; Thursday is a single-stage welcome party on What Stage (Skrillex).</li>
								<li><b>That Tent moved into the What Stage field</b>; the Where? flying saucer moved inside Centeroo; Bonnie Roo's Brews &amp; Sports Bar takes That Tent's old spot.</li>
								<li>New 1-day and 2-day passes.</li>
							</ul>
						</div>
					</details>

					<details class="info-sec">
						<summary>🏆 Roo Quest & your festival buddy</summary>
						<div class="sec-body">
							<div id="petCard"></div>
							<div id="questCard"></div>
						</div>
					</details>

					<details class="info-sec">
						<summary>🔗 Official links</summary>
						<div class="sec-body">
							<ul>
								<li><a href="https://www.bonnaroo.com" target="_blank" rel="noopener">bonnaroo.com</a> · <a href="https://www.bonnaroo.com/guide" target="_blank" rel="noopener">official guide hub</a> · <a href="https://support.bonnaroo.com/hc/en-us" target="_blank" rel="noopener">FAQ</a></li>
								<li><a href="https://support.bonnaroo.com/hc/en-us/articles/4402685420948-Centeroo-Outeroo-Maps" target="_blank" rel="noopener">Official Centeroo + Outeroo maps</a></li>
								<li>Official app: <b>Festiverse</b> — <a href="https://festiverse.onelink.me/oyeq/r3mvo79k" target="_blank" rel="noopener">download (iOS/Android)</a></li>
								<li><a href="https://www.instagram.com/bonnaroo/" target="_blank" rel="noopener">@bonnaroo on Instagram</a> · <a href="https://x.com/bonnaroo" target="_blank" rel="noopener">@Bonnaroo on X</a></li>
								<li>info@bonnaroo.com · accessibility: access@bonnaroo.com</li>
							</ul>
						</div>
					</details>
				</div>
				<footer class="app-foot">
					<p>
						Unofficial fan-made guide · not affiliated with Bonnaroo or C3 Presents. Verify
						details at <a href="https://www.bonnaroo.com" target="_blank" rel="noopener">bonnaroo.com</a>.
						Schedule data compiled June 2026 — set times can change; the official Bonnaroo app has
						the final word.
					</p>
					<p>Built with ❤️ at <a href="https://alkem.dev" target="_blank" rel="noopener">alkem.dev</a>. Stay hydrated. Radiate positivity. 🌈</p>
				</footer>
			</section>
		</main>

		<nav class="bottombar">
			<button class="nav-btn" data-nav="schedule"><span class="nav-ico">🎸</span>Schedule</button>
			<button class="nav-btn" data-nav="map"><span class="nav-ico">🗺️</span>Map</button>
			<button class="nav-btn" data-nav="plan"
				><span class="nav-ico">⭐</span>My Roo<span class="nav-badge" id="favCount" hidden></span></button
			>
			<button class="nav-btn" data-nav="info"><span class="nav-ico">🧭</span>Guide</button>
		</nav>

		<!-- artist detail sheet -->
		<div class="sheet-wrap" id="sheetWrap" hidden>
			<div class="sheet">
				<div class="sheet-img" id="sheetImg">
					<button class="sheet-close" id="sheetClose" aria-label="Close">✕</button>
				</div>
				<div class="sheet-body">
					<div class="sheet-title">
						<h3 id="sheetArtist"></h3>
						<span class="genre-tag big" id="sheetGenre"></span>
					</div>
					<p class="sheet-desc" id="sheetDesc"></p>
					<p class="sheet-bio" id="sheetBio"></p>
					<div class="sheet-links" id="sheetLinks"></div>
					<p class="sheet-when"><span id="sheetWhen"></span> · <b id="sheetStage"></b></p>
					<div class="sheet-actions">
						<button class="sheet-btn" id="sheetGoing">☆ Add to My Roo</button>
						<a class="sheet-btn sheet-spotify" id="sheetSpotify" href="#" target="_blank" rel="noopener">▶ Spotify</a>
						<button class="sheet-btn" id="sheetMap">🗺️ Stage</button>
					</div>
				</div>
			</div>
		</div>

		<!-- pin creation sheet -->
		<div class="sheet-wrap" id="pinSheetWrap" hidden>
			<div class="sheet pin-sheet">
				<div class="sheet-body">
					<h3>Drop a pin</h3>
					<p class="pin-hint">Mark your camp, your friends' camps, the car, a meetup spot…</p>
					<div class="pin-emojis" id="pinEmojis"></div>
					<input type="text" id="pinName" placeholder="Name it — “Jake's camp”, “our car”…" maxlength="40" />
					<div class="sheet-actions">
						<button class="sheet-btn sheet-primary" id="pinPlace">Tap map to place</button>
						<button class="sheet-btn" id="pinHere">📍 Place at my location</button>
						<button class="sheet-btn" id="pinCancel">Cancel</button>
					</div>
				</div>
			</div>
		</div>

		<!-- your sharing identity: icon + name -->
		<div class="sheet-wrap" id="nameSheetWrap" hidden>
			<div class="sheet pin-sheet">
				<div class="sheet-body">
					<h3>Your sharing name</h3>
					<p class="pin-hint">Shown on the plans, links & QR codes you share with friends.</p>
					<div class="pin-emojis" id="nameEmojis"></div>
					<input type="text" id="nameInput" placeholder="Your name" maxlength="24" enterkeyhint="done" />
					<div class="sheet-actions">
						<button class="sheet-btn sheet-primary" id="nameSave">Save</button>
						<button class="sheet-btn" id="nameCancel">Cancel</button>
					</div>
				</div>
			</div>
		</div>

		<!-- rich preview when importing a friend's shared plan -->
		<div class="sheet-wrap" id="importWrap" hidden>
			<div class="sheet import-sheet">
				<div class="sheet-body">
					<h3 id="importTitle"></h3>
					<p class="pin-hint" id="importSub"></p>
					<div class="import-list" id="importList"></div>
					<div class="sheet-actions">
						<button class="sheet-btn sheet-primary" id="importSave">Save to My Roo</button>
						<button class="sheet-btn" id="importCancel">Not now</button>
					</div>
				</div>
			</div>
		</div>

		<!-- notification settings (push) -->
		<div class="sheet-wrap" id="notifWrap" hidden>
			<div class="sheet pin-sheet">
				<div class="sheet-body">
					<h3>🔔 Notifications</h3>
					<p class="pin-hint">A buzz before your starred sets — even with the app closed.</p>
					<label class="notif-row"><span>🎵 Set reminders</span><input type="checkbox" id="notifSets" /></label>
					<label class="notif-row notif-sub"
						><span>Remind me</span>
						<select id="notifLead">
							<option value="10">10 min before</option>
							<option value="20" selected>20 min before</option>
							<option value="30">30 min before</option>
						</select></label
					>
					<label class="notif-row"><span>⚠️ Severe weather alerts</span><input type="checkbox" id="notifWeather" /></label>
					<p class="pin-hint" id="notifNote"></p>
					<div class="sheet-actions">
						<button class="sheet-btn sheet-primary" id="notifSave">Save</button>
						<button class="sheet-btn" id="notifClose">Close</button>
					</div>
				</div>
			</div>
		</div>

		<!-- Share hub: QR (white for sunlight scanning) + text-a-friend buttons -->
		<div class="qr-wrap" id="qrWrap" hidden>
			<div class="qr-name" id="qrName"></div>
			<canvas id="qrCanvas"></canvas>
			<div class="qr-hint">Scan to open my plan — no app needed</div>
			<div class="qr-share-actions">
				<button class="share-opt share-opt-primary" id="shareLink">📲 Text a friend the link</button>
				<button class="share-opt" id="shareFull">📋 Share full schedule</button>
			</div>
			<button class="tool-btn qr-close" id="qrClose">Close</button>
		</div>

		<!-- take-me-home compass -->
		<div class="compass-wrap" id="compassWrap" hidden>
			<button class="omap-close compass-close" id="compassClose" aria-label="Close">✕</button>
			<button class="compass-name" id="compassName"></button>
			<button class="compass-cycle" id="compassCycle" hidden></button>
			<div class="compass-arrow-box"><div class="compass-arrow" id="compassArrow">⬆</div></div>
			<div class="compass-dist" id="compassDist"></div>
			<div class="compass-hint" id="compassHint"></div>
			<div class="compass-age" id="compassAge"></div>
		</div>

		<!-- official map viewer -->
		<div class="omap-wrap" id="omapWrap" hidden>
			<div class="omap-top">
