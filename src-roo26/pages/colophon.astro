		<script is:inline>
			// scroll-spy: highlight the current section in the TOC
			const links = [...document.querySelectorAll('nav.toc a')]
			const byId = Object.fromEntries(links.map((a) => [a.getAttribute('href').slice(1), a]))
			const io = new IntersectionObserver(
				(entries) => {
					for (const e of entries) {
						if (e.isIntersecting) {
							links.forEach((l) => l.classList.remove('on'))
							byId[e.target.id]?.classList.add('on')
						}
					}
				},
				{ rootMargin: '-10% 0px -80% 0px' },
			)
			document.querySelectorAll('section[id]').forEach((s) => io.observe(s))

			// reveal-on-scroll (JS-added so content stays visible without JS)
			const rev = [...document.querySelectorAll('main section, .stats')]
			rev.forEach((el) => el.classList.add('reveal'))
			const ro = new IntersectionObserver(
				(entries) => {
					for (const e of entries) {
						if (e.isIntersecting) {
							e.target.classList.add('in')
							ro.unobserve(e.target)
						}
					}
				},
				{ rootMargin: '0px 0px -8% 0px' },
			)
			rev.forEach((el) => ro.observe(el))
</script>
