# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.
# Prefer exporting the token instead of committing it:
#   export TF_VAR_cloudflare_api_token=...

cloudflare_account_id = "your-account-id"
zone_id               = "alkem-dev-zone-id"

# Optional overrides (defaults shown):
# project_name         = "roo26"
# production_branch    = "main"
# domain               = "roo26.alkem.dev"
# compatibility_date   = "2026-06-01"

# Turn on the crew location-sharing feature (creates + binds ROO_KV):
# enable_crew = true

# Web Analytics is on by default; set false to skip:
# enable_web_analytics = true
