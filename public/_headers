# Cloudflare Pages headers. Copied to the deploy root by Astro (publicDir).

# Hashed, immutable build assets — cache hard.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Service worker must always revalidate so updates ship promptly.
/roo26-sw.js
  Cache-Control: no-cache

# Web app manifests.
/*.webmanifest
  Cache-Control: public, max-age=86400

# Official festival map images.
/roo26-map-*.webp
  Cache-Control: public, max-age=86400

# Baseline hardening. No CSP on purpose: the app loads external map tiles,
# weather/radar APIs, and artist images cross-origin, and is battle-tested as-is.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(self), camera=(), microphone=()
